# ─── EduVerse Email Server Environment ───
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Mailjet API credentials (required for primary email delivery)
MAILJET_API_KEY=your_mailjet_api_key_here
MAILJET_API_SECRET=your_mailjet_api_secret_here

# Sender identity (must match your verified Mailjet domain)
FROM_EMAIL=noreply@eduverse-official.me
FROM_NAME=EduVerse Team

# SMTP fallback (optional — used if Mailjet fails)
# Example: Gmail App Password, SendGrid, Brevo, or any SMTP provider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password

# Firebase Realtime Database URL
FIREBASE_DB_URL=https://eduverse-8780a-default-rtdb.firebaseio.com

# Port for the email server
PORT=3001
