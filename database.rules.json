{
  "rules": {
    
    "admin": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    
    "student": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid || root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        "certificates": {
          ".indexOn": ["courseId", "quizId"]
        },
        "payments": {
          ".indexOn": ["courseId"]
        }
      }
    },
    
    "teacher": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid || root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        "earnings": {
          ".write": "auth != null"
        },
        "totalEarnings": {
          ".write": "auth != null"
        },
        "courses": {
          ".read": "auth != null",
          "$courseId": {
            ".read": "auth != null",
            ".write": "auth != null",
            "enrolledStudents": {
              ".read": "auth != null",
              "$studentUid": {
                ".read": "auth != null",
                ".write": "auth != null"
              }
            },
            "reviews": {
              ".read": "auth != null",
              "$reviewId": {
                ".write": "auth != null"
              }
            }
          }
        },
        "reviews": {
          ".read": "auth != null",
          "$reviewId": {
            ".write": "auth != null"
          }
        }
      }
    },
    
    "courses": {
      ".read": "auth != null",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["teacherUid", "createdAt"],
      "$courseId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "enrolledStudents": {
          ".read": "auth != null",
          "$studentUid": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "reviews": {
          ".read": "auth != null",
          "$studentId": {
            ".write": "auth != null"
          }
        },
        "questions": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["createdAt"],
          "$questionId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "videos": {
          ".read": "auth != null",
          ".write": "auth != null || root.child('admin').child(auth.uid).child('role').val() === 'admin'",
          "$videoId": {
            ".read": "auth != null",
            ".write": "auth != null || root.child('admin').child(auth.uid).child('role').val() === 'admin'"
          }
        },
        "quizzes": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$quizId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "assignments": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$assignmentId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    
    "quizzes": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["courseId", "teacherId"],
      "$quizId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    
    "quiz_attempts": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["quizId", "studentId"],
      "$attemptId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    
    "assignments": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["courseId", "teacherId"],
      "$assignmentId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    
    "assignment_submissions": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["assignmentId", "studentId"],
      "$submissionId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    
    "flagged_content": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null || root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      "$flagId": {
        ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null || root.child('admin').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    
    "qa": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$courseId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$questionId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    
    "course_announcements": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$courseId": {
        ".indexOn": ["createdAt"]
      }
    },
    
    
    "moderation": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      "logs": {
        ".indexOn": ["timestamp"]
      }
    },
    
    "moderation_resolved": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
    },
    
    "warnings": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin' || $uid === auth.uid",
        ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    
    "content_reports": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$reportId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "user_reports": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null"
    },
    "support_tickets": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      ".indexOn": ["createdAt", "updatedAt", "userId", "status"],
      "$ticketId": {
        ".read": "auth != null && (root.child('admin').child(auth.uid).child('role').val() === 'admin' || root.child('support_tickets').child($ticketId).child('userId').val() === auth.uid)",
        ".write": "auth != null && (root.child('admin').child(auth.uid).child('role').val() === 'admin' || root.child('support_tickets').child($ticketId).child('userId').val() === auth.uid || !data.exists())"
      }
    },
    "platform_settings": {
      ".read": "auth != null",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
    },
    "platform_announcements": {
      ".read": "auth != null",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["sentAt"],
      "$announcementId": {
        ".read": "auth != null",
        ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "admin_audit_log": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["timestamp"],
      "$entryId": {
        ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "admin_logs": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
    },
    "deleted_courses": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      "$courseId": {
        ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        ".write": "root.child('admin').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "payments": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["teacherId", "teacherUid", "studentUid", "courseId", "timestamp"],
      "$paymentId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "reports": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      "$reportId": {
        ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['reporterId', 'reason', 'targetId']) && newData.child('reporterId').val() === auth.uid"
      }
    },
    "flags": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      "$flagId": {
        ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['reporterId', 'reason']) && newData.child('reporterId').val() === auth.uid"
      }
    },
    "revenue": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      "$transactionId": {
        ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null"
      }
    },
    "revenue_daily": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null"
    },
    "revenue_monthly": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null"
    },
    "revenue_total": {
      ".read": "root.child('admin').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null"
    },
    "userPreferences": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },
    "bookmarks": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },
    "study_streaks": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },
    "course_notes": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid",
        "$courseId": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "learning_stats": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },
    "chat_history": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid",
        ".indexOn": ["updatedAt"],
        "$chatId": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && $uid === auth.uid",
          "messages": {
            ".read": "auth != null && $uid === auth.uid",
            ".write": "auth != null && $uid === auth.uid"
          }
        }
      }
    },
    "chat_sessions": {
      ".read": "auth != null",
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "chat_messages": {
      ".read": "auth != null",
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$messageId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "notification_preferences": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "user_customization": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "notifications": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["createdAt"],
        "$notificationId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "verification_codes": {
      "$emailKey": {
        ".read": true,
        ".write": true
      }
    },
    "password_reset_attempts": {
      "$emailKey": {
        ".read": true,
        ".write": true
      }
    },
    "verification_code_attempts": {
      "$emailKey": {
        ".read": true,
        ".write": true
      }
    },
    "registered_emails": {
      ".read": true,
      "$emailKey": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    ".read": false,
    ".write": false
  }
}
